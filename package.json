{
  "name": "project-markdown-explorer",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "description": "A comprehensive Markdown Explorer built with Expo and Electron",
  "author": "alpha300uk",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "electron": "electron electron-main.js",
    "build:desktop": "npx expo export --platform web && electron-builder",
    "build:desktop-all": "npx expo export --platform web && electron-builder -mwl"
  },
  "build": {
    "appId": "com.alpha300uk.markdownexplorer",
    "productName": "Markdown Explorer",
    "directories": {
      "output": "dist-desktop"
    },
    "extraMetadata": {
      "main": "electron-main.js"
    },
    "files": [
      "dist/**/*",
      "electron-main.js"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@aarkue/tiptap-math-extension": "^1.4.0",
    "@codemirror/lang-markdown": "^6.5.0",
    "@expo/vector-icons": "^15.0.3",
    "@google/generative-ai": "^0.24.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@tiptap/extension-blockquote": "^3.20.1",
    "@tiptap/extension-bold": "^3.20.1",
    "@tiptap/extension-bubble-menu": "^3.20.1",
    "@tiptap/extension-code": "^3.20.1",
    "@tiptap/extension-code-block": "^3.20.1",
    "@tiptap/extension-color": "^3.20.1",
    "@tiptap/extension-heading": "^3.20.1",
    "@tiptap/extension-image": "^3.20.1",
    "@tiptap/extension-italic": "^3.20.1",
    "@tiptap/extension-strike": "^3.20.1",
    "@tiptap/extension-text-style": "^3.20.1",
    "@tiptap/extension-youtube": "^3.20.1",
    "@tiptap/pm": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@uiw/react-codemirror": "^4.25.7",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "date-fns": "^4.1.0",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "katex": "^0.16.37",
    "lucide-react": "^1.8.0",
    "mermaid": "^11.12.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "^10.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "slugify": "^1.6.9",
    "tiptap-markdown": "^0.9.0",
    "unist-util-visit": "^5.1.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/file-saver": "^2.0.7",
    "@types/jest": "^29.5.12",
    "@types/jszip": "^3.4.0",
    "@types/react": "~19.1.0",
    "@types/react-dom": "~19.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.1",
    "ts-jest": "^29.1.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
